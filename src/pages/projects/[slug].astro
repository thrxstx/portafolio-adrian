---
import Layout from "../../layouts/Layout.astro";
import { content } from "../../data/content";

export function getStaticPaths() {
    return content.work.projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} — Adrian David`}>
    <article
        class="project-detail min-h-screen"
        style="padding: 8rem var(--spacing-margin-desktop) var(--spacing-stack-xl);"
        transition:name={`project-${project.slug}`}
    >
        <div class="mx-auto" style="max-width: var(--spacing-container);">
            <a
                href="/#work"
                class="back-link group mb-12 inline-flex items-center gap-2 text-sm font-medium tracking-[0.1em] uppercase transition-colors duration-300"
                style="font-family: var(--font-inter); color: var(--color-on-surface-variant);"
            >
                <span
                    data-lang="en"
                    class="inline-block transition-transform duration-300 group-hover:-translate-x-1"
                    >{content.projects.back.en}</span
                >
                <span
                    data-lang="es"
                    class="inline-block transition-transform duration-300 group-hover:-translate-x-1"
                    >{content.projects.back.es}</span
                >
            </a>

            <div class="grid gap-12 lg:grid-cols-[1fr_320px]">
                <div class="project-main">
                    <div
                        class="project-hero-media relative mb-8 aspect-16/9 overflow-hidden border"
                        style="border-color: var(--color-surface-container-high);"
                    >
                        <img
                            src={project.image}
                            alt={project.title}
                            class="absolute inset-0 h-full w-full object-cover"
                        />
                    </div>

                    <h1
                        class="project-title mb-6 text-4xl font-bold leading-[1.1] tracking-[-0.02em] lg:text-5xl"
                        style="font-family: var(--font-hanken); color: var(--color-on-surface);"
                    >
                        {project.title}
                    </h1>

                    <p
                        class="project-desc mb-8 text-lg leading-relaxed"
                        style="font-family: var(--font-inter); color: var(--color-on-surface-variant);"
                    >
                        <span data-lang="en">{project.description.en}</span>
                        <span data-lang="es">{project.description.es}</span>
                    </p>

                    <div class="project-content prose prose-invert max-w-none">
                        <h2
                            class="mb-4 text-sm font-medium tracking-[0.1em] uppercase"
                            style="font-family: var(--font-inter); color: var(--color-gold);"
                        >
                            <span data-lang="en"
                                >{content.projects.overview.en}</span
                            >
                            <span data-lang="es"
                                >{content.projects.overview.es}</span
                            >
                        </h2>
                        <p
                            style="font-family: var(--font-inter); color: var(--color-on-surface-variant); line-height: 1.8;"
                        >
                            <span data-lang="en">{project.details?.en}</span>
                            <span data-lang="es">{project.details?.es}</span>
                        </p>
                    </div>
                </div>

                <aside class="project-sidebar">
                    <div
                        class="sticky border p-6"
                        style="top: 6rem; border-color: var(--color-surface-container-high);"
                    >
                        <div class="mb-6">
                            <h3
                                class="mb-3 text-xs font-medium tracking-[0.1em] uppercase"
                                style="font-family: var(--font-inter); color: var(--color-gold);"
                            >
                                <span data-lang="en"
                                    >{content.projects.tech.en}</span
                                >
                                <span data-lang="es"
                                    >{content.projects.tech.es}</span
                                >
                            </h3>
                            <div class="flex flex-wrap gap-2">
                                {
                                    project.technologies.map((tech) => (
                                        <span
                                            class="border px-3 py-1.5 text-xs font-medium tracking-[0.05em] uppercase"
                                            style="font-family: var(--font-inter); border-color: var(--color-surface-container-high); color: var(--color-on-surface-variant);"
                                        >
                                            {tech}
                                        </span>
                                    ))
                                }
                            </div>
                        </div>

                        <div>
                            <h3
                                class="mb-3 text-xs font-medium tracking-[0.1em] uppercase"
                                style="font-family: var(--font-inter); color: var(--color-gold);"
                            >
                                <span data-lang="en"
                                    >{content.projects.links.en}</span
                                >
                                <span data-lang="es"
                                    >{content.projects.links.es}</span
                                >
                            </h3>
                            <div class="flex flex-col gap-3">
                                {
                                    project.links.live && (
                                        <a
                                            href={project.links.live}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center justify-center gap-2 border px-6 py-3 text-sm font-medium tracking-[0.1em] uppercase transition-all duration-300"
                                            style="font-family: var(--font-inter); border-color: var(--color-gold); color: var(--color-gold);"
                                        >
                                            Live Site
                                            <svg
                                                class="h-4 w-4"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                                <polyline points="15 3 21 3 21 9" />
                                                <line
                                                    x1="10"
                                                    y1="14"
                                                    x2="21"
                                                    y2="3"
                                                />
                                            </svg>
                                        </a>
                                    )
                                }
                                {
                                    project.links.github && (
                                        <a
                                            href={project.links.github}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center justify-center gap-2 border px-6 py-3 text-sm font-medium tracking-[0.1em] uppercase transition-all duration-300"
                                            style="font-family: var(--font-inter); border-color: var(--color-surface-container-high); color: var(--color-on-surface-variant);"
                                        >
                                            <svg
                                                class="h-4 w-4"
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                            >
                                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                            </svg>
                                            Source Code
                                        </a>
                                    )
                                }
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </article>
</Layout>

<style>
    @media (max-width: 768px) {
        .project-detail {
            padding: 5rem var(--spacing-margin-mobile) var(--spacing-stack-lg) !important;
        }

        .project-title {
            font-size: 2rem !important;
        }

        .project-desc {
            font-size: 1rem !important;
        }

        .project-hero-media {
            aspect-ratio: 4/3 !important;
        }

        .project-detail .grid {
            grid-template-columns: 1fr !important;
        }
    }
</style>
