---

<span class="lang-toggle" aria-label="Toggle language">
  <button
    class="lang-btn"
    data-lang="es"
    type="button"
  >
    ES
  </button>
  <span class="lang-divider" aria-hidden="true">/</span>
  <button
    class="lang-btn"
    data-lang="en"
    type="button"
  >
    EN
  </button>
</span>

<style>
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-inter);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .lang-btn {
    background: none;
    border: none;
    color: var(--color-on-surface-variant);
    cursor: pointer;
    padding: 0.25rem 0.375rem;
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    transition: color 0.3s ease;
  }

  .lang-btn:hover {
    color: var(--color-gold);
  }

  .lang-btn[data-active] {
    color: var(--color-on-surface);
    font-weight: 600;
  }

  .lang-divider {
    color: var(--color-outline-variant);
    font-size: 0.75rem;
  }
</style>
