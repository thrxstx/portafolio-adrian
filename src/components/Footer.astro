---
import { content } from "../data/content";
---

<footer
  class="border-t text-center"
  style="border-color: var(--color-surface-container-high); padding: var(--spacing-stack-md) var(--spacing-margin-desktop);"
>
  <div class="mx-auto" style="max-width: var(--spacing-container);">
    <p
      class="text-sm leading-relaxed"
      style="font-family: var(--font-inter); color: var(--color-on-surface-variant);"
    >
      <span data-lang="en">{content.footer.copyright.en}</span>
      <span data-lang="es">{content.footer.copyright.es}</span>
    </p>
    <p
      class="mt-1 text-xs tracking-[0.1em] uppercase"
      style="font-family: var(--font-inter); color: var(--color-outline-variant);"
    >
      <span data-lang="en">{content.footer.builtWith.en}</span>
      <span data-lang="es">{content.footer.builtWith.es}</span>
    </p>
  </div>
</footer>

<style>
  @media (max-width: 768px) {
    footer {
      padding: var(--spacing-stack-md) var(--spacing-margin-mobile) !important;
    }
  }
</style>
