---
import { content } from "../data/content";

const codeHtml = `<span class="tok-c">// about.js</span>
<span class="tok-kw">const</span> <span class="tok-var">developer</span> = {
  <span class="tok-key">name</span>: <span class="tok-str">'Adrian David'</span>,
  <span class="tok-key">stack</span>: [<span class="tok-str">'React'</span>, <span class="tok-str">'Bun'</span>, <span class="tok-str">'TypeScript'</span>],
  <span class="tok-key">focus</span>: <span class="tok-str">'UI Engineering'</span>,
  <span class="tok-key">location</span>: <span class="tok-str">'Remote'</span>,
  <span class="tok-key">available</span>: <span class="tok-kw">true</span>,
};`;
---

<section
    id="about"
    class="reveal"
    style="padding: var(--spacing-stack-lg) var(--spacing-margin-desktop);"
>
    <div class="mx-auto" style="max-width: var(--spacing-container);">
        <div class="about-grid">
            <div class="about-text-col">
                <h2
                    class="section-label mb-8 text-sm font-medium tracking-widest uppercase"
                    style="font-family: var(--font-inter); color: var(--color-gold);"
                >
                    <span data-lang="en">{content.about.title.en}</span>
                    <span data-lang="es">{content.about.title.es}</span>
                </h2>
                <p
                    class="mb-6 text-lg leading-relaxed"
                    style="font-family: var(--font-inter); color: var(--color-on-surface-variant);"
                >
                    <span data-lang="en">{content.about.bio1.en}</span>
                    <span data-lang="es">{content.about.bio1.es}</span>
                </p>
                <p
                    class="text-lg leading-relaxed"
                    style="font-family: var(--font-inter); color: var(--color-on-surface-variant);"
                >
                    <span data-lang="en">{content.about.bio2.en}</span>
                    <span data-lang="es">{content.about.bio2.es}</span>
                </p>
            </div>
            <div class="about-code-col">
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-dot code-dot--red"></span>
                        <span class="code-dot code-dot--yellow"></span>
                        <span class="code-dot code-dot--green"></span>
                        <span class="code-filename">developer.js</span>
                    </div>
                    <pre
                        class="code-block-body"><code set:html={codeHtml} /></pre>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    #about {
        border-top: 1px solid var(--color-surface-container-high);
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: start;
    }

    .code-block {
        border: 1px solid rgba(197, 160, 89, 0.2);
        border-radius: 0.5rem;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.3);
        transition:
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    .code-block:hover {
        border-color: rgba(197, 160, 89, 0.5);
        box-shadow: 0 0 30px rgba(197, 160, 89, 0.08);
    }

    .code-block-header {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.625rem 0.75rem;
        border-bottom: 1px solid rgba(197, 160, 89, 0.1);
        background: rgba(0, 0, 0, 0.4);
    }

    .code-dot {
        width: 0.625rem;
        height: 0.625rem;
        border-radius: 50%;
    }

    .code-dot--red {
        background: #ff5f56;
    }
    .code-dot--yellow {
        background: #ffbd2e;
    }
    .code-dot--green {
        background: #27c93f;
    }

    .code-filename {
        margin-left: auto;
        font-family: var(--font-inter);
        font-size: 0.7rem;
        color: rgba(197, 160, 89, 0.5);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .about-code-col {
        min-width: 0;
    }

    .code-block-body {
        margin: 0;
        padding: 1.25rem;
        font-size: 0.875rem;
        line-height: 1.6;
        font-family: "Courier New", Courier, monospace;
        color: var(--color-on-surface-variant);
        overflow-x: auto;
        white-space: pre;
    }

    :global(.tok-kw) {
        color: var(--color-gold);
    }
    :global(.tok-var) {
        color: #e9c176;
    }
    :global(.tok-key) {
        color: #dab36a;
    }
    :global(.tok-str) {
        color: #7cbf7c;
    }
    :global(.tok-c) {
        color: rgba(197, 160, 89, 0.4);
        font-style: italic;
    }

    @media (min-width: 768px) {
        .about-grid {
            grid-template-columns: 1.2fr 1fr;
            gap: 4rem;
        }

        .about-text-col {
            max-width: 580px;
        }
    }

    @media (max-width: 767px) {
        #about {
            padding: var(--spacing-stack-md) var(--spacing-margin-mobile) !important;
        }

        .code-block-body {
            font-size: 0.75rem;
            padding: 1rem;
        }
    }
</style>
